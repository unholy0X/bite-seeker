{
  "expo": {
    "scheme": "biteseeker",
    "name": "Bite Seeker",
    "slug": "bite-seeker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "bundleIdentifier": "com.biteseeker.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Bite Seeker uses the camera to scan recipes from photos and pantry items",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.biteseeker.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#030712"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Bite Seeker accesses your photos to extract recipes",
          "cameraPermission": "Bite Seeker uses the camera to scan recipes and pantry items",
          "microphonePermission": false
        }
      ],
      "@sentry/react-native",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#B6FF00",
          "sounds": []
        }
      ],
      "expo-image"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ced04bd-6585-47ed-9d03-c6259623fe42"
      }
    },
    "owner": "0xunholy"
  }
}
